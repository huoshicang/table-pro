{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "include": [
    "env.d.ts",
    "src/index.ts",
    "src/types/**/*.ts",
    "src/composables/**/*.ts",
    "src/utils/**/*.ts"
  ],
  "exclude": [
    "src/main.ts",
    "src/App.vue",
    "src/components/**/*.vue",
    "src/**/__tests__/*"
  ],
  "compilerOptions": {
    "declaration": true,
    "declarationDir": "./dist",
    "emitDeclarationOnly": true,
    "noUncheckedIndexedAccess": true,
    "paths": {
      "@/*": ["./src/*"]
    },
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.lib.tsbuildinfo"
  }
}
